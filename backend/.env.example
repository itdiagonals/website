# Secrets below are placeholders and are REJECTED at startup by design.
# Generate real values, e.g.: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_generate_a_32_byte_random_secret_for_payload
REFRESH_TOKEN_SECRET=CHANGE_ME_generate_a_32_byte_random_secret_for_refresh
ACCESS_TOKEN_SECRET=CHANGE_ME_generate_a_32_byte_random_secret_for_access
CSRF_AUTH_KEY=CHANGE_ME_generate_a_32_byte_random_secret_for_csrf
BACKEND_GIN_MODE=release
BACKEND_TRUSTED_PROXIES=127.0.0.1,::1
BACKEND_CORS_ALLOWED_ORIGINS=https://staging.your-domain.com,https://your-domain.com
BACKEND_CSRF_TRUSTED_ORIGINS=https://staging.your-domain.com,https://your-domain.com

REDIS_URL=redis://:diagonals@redis:6379

COOKIE_DOMAIN=your-domain.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
CSRF_COOKIE_MAX_AGE_SECONDS=43200

S3_ENDPOINT=https://s3.your-domain.com
S3_REGION=us-east-1
S3_BUCKET=diagonals-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

BACKEND_DATABASE_URL=postgresql://username:password@postgres:5432/diagonals

BITESHIP_BASE_URL=https://api.biteship.com
BITESHIP_API_KEY=your_biteship_api_key
BITESHIP_ORIGIN_AREA_ID=your_biteship_origin_area_id
BITESHIP_ORIGIN_CONTACT_NAME=your_origin_contact_name
BITESHIP_ORIGIN_CONTACT_PHONE=your_origin_contact_phone
BITESHIP_ORIGIN_CONTACT_EMAIL=your_origin_contact_email
BITESHIP_ORIGIN_ADDRESS=your_origin_full_address
BITESHIP_ORIGIN_POSTAL_CODE=your_origin_postal_code
BITESHIP_WEBHOOK_SECRET=your_biteship_webhook_secret
BITESHIP_WEBHOOK_TOKEN=your_biteship_webhook_token
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_FINISH_URL=https://your-domain.com/checkout/result
MIDTRANS_APPEND_NOTIFICATION_URL=https://your-domain.com/api/v1/payments/midtrans/notification

MAILTRAP_API_KEY=your_mailtrap_api_key
MAILTRAP_API_BASE_URL=https://send.api.mailtrap.io
MAILTRAP_FROM_EMAIL=hello@demomailtrap.co
MAILTRAP_FROM_NAME=Diagonals

RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Diagonals
