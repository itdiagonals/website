NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Public browser calls should stay relative when frontend proxies /api/v1
NEXT_PUBLIC_API_URL=/api/v1

# SEO / Canonical domain override (used for metadataBase, sitemap, robots)
# Production: https://diagonals.id | Staging: https://preview.diagonals.id
# Falls back automatically based on VERCEL_ENV / VERCEL_URL if not set
NEXT_PUBLIC_SITE_URL=https://diagonals.id

# Midtrans Snap (sandbox vs production)
# sandbox: https://app.sandbox.midtrans.com/snap/snap.js
# production: https://app.midtrans.com/snap/snap.js
NEXT_PUBLIC_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js
NEXT_PUBLIC_MIDTRANS_ENV=sandbox
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server-side requests from Next.js to backend service inside Dokploy/Docker network
INTERNAL_API_URL=http://backend:8080/api/v1

# If root app still uses Payload-side integrations, keep the rest as needed
PAYLOAD_SECRET=supersecretkey
DATABASE_URL=postgresql://diagonals:diagonals@localhost:5432/diagonals
PAYLOAD_ENABLE_PUSH=true
BACKEND_DATABASE_URL=postgresql://diagonals:diagonals@localhost:5432/diagonals
BACKEND_GIN_MODE=release
BACKEND_TRUSTED_PROXIES=127.0.0.1,::1
REDIS_URL=redis://:diagonals@localhost:6379

# Local infra credentials (docker-compose). MUST be changed for any
# non-local deployment; ports bind to 127.0.0.1 only by default.
POSTGRES_DB=diagonals
POSTGRES_USER=diagonals
POSTGRES_PASSWORD=diagonals
REDIS_PASSWORD=diagonals
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=payload-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
